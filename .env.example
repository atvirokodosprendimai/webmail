# ORBITAL webmail — env config
# Copy to .env and fill in.

WEBMAIL_LISTEN=:8080
WEBMAIL_BASE_URL=http://localhost:8080
WEBMAIL_DB_PATH=./data/webmail.db
WEBMAIL_UPLOADS_DIR=./data/uploads

# 32+ random bytes (hex or base64). Generate: openssl rand -hex 32
WEBMAIL_SESSION_KEY=dev-only-change-me-32-bytes-min!!
WEBMAIL_SESSION_MAX_AGE=720h

# Shared IMAP mailbox — single account, all webmail users see it.
IMAP_HOST=127.0.0.1
IMAP_PORT=993
IMAP_TLS=tls                       # tls | starttls | none
IMAP_USERNAME=team@example.com
IMAP_PASSWORD=
IMAP_SENT_FOLDER=Sent
IMAP_TRASH_FOLDER=Trash
IMAP_ARCHIVE_FOLDER=Archive
IMAP_NOTES_FOLDER=Notes

# Shared SMTP outbound.
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_TLS=starttls                  # tls | starttls | none
SMTP_USERNAME=team@example.com
SMTP_PASSWORD=

# Poll worker tuning.
POLL_INTERVAL=60s
FLAG_SYNC_EVERY=10                 # reconcile \Seen/\Flagged every N cycles
ATTACHMENT_MAX_BYTES=26214400      # 25 MiB

# Migration knob.
MIGRATE_ON_BOOT=true
